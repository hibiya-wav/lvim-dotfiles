{
    // --- VSC GENERAL SETTINGS ---
    "telemetry.editStats.enabled": false,
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "chat.disableAIFeatures": false,
    "editor.lineHeight": 1.3,
    "window.zoomLevel": -0.5,
    "editor.fontSize": 16,
    "editor.allowVariableLineHeights": false,
    "editor.stickyScroll.enabled": false,
    
    "java.maven.downloadSources": true,
    "terminal.integrated.fontSize": 16,
    "editor.bracketPairColorization.enabled": false,
    "chat.commandCenter.enabled": false,
    "workbench.settings.showAISearchToggle": false,
    "terminal.integrated.defaultProfile.osx": "bash",
    "workbench.editor.enablePreview": false,
    "workbench.editor.empty.hint": "hidden",
    "workbench.startupEditor": "none",
    "editor.minimap.enabled": false,
    "explorer.confirmDelete": false,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.cursorBlinking": true,
    "chat.agent.enabled": false,
    "editor.experimentalGpuAcceleration": "on",
    "files.insertFinalNewline": true,
    "files.eol": "\n",

    // --- FONT STYLING (KEEPING YOUR IOSEVKA EVERYWHERE) ---
    "editor.fontFamily": "Iosevka",
    "editor.codeLensFontFamily": "Iosevka",
    "editor.inlayHints.fontFamily": "Iosevka",
    "editor.inlineSuggest.fontFamily": "Iosevka",
    "debug.console.fontFamily": "Iosevka",
    "terminal.integrated.fontFamily": "Iosevka",
    "notebook.markup.fontFamily": "Iosevka",
    "notebook.output.fontFamily": "Iosevka",
    "chat.editor.fontFamily": "Iosevka",
    "scm.inputFontFamily": "Iosevka",
    "custom-ui-style.font.sansSerif": "Iosevka",
    "custom-ui-style.font.monospace": "Iosevka",

    // --- NEOVIM STYLE UI & PERFORMANCE ---
    "editor.lineNumbers": "relative",
    "editor.cursorSurroundingLines": 8,
    "editor.scrollBeyondLastLine": false,
    // "editor.scrollbar.horizontal": "hidden",
    // "editor.scrollbar.vertical": "hidden",
    "workbench.reduceMotion": "on",
    "workbench.tree.indent": 25,
    "workbench.tree.renderIndentGuides": "always",
    "editor.detectIndentation": false,
    "search.smartCase": true,

    // --- VIM CONFIGURATION ---
    "vim.leader": " ",
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.incsearch": true,
    "vim.hlsearch": true,
    "vim.sneak": true,
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.duration": 200,
    "vim.searchHighlightColor": "rgba(180, 142, 173, 0.5)",

    "vim.handleKeys": {
        "<C-d>": true,
        "<C-u>": true,
        "<C-f>": false,
        "<C-n>": false,
    },

    "vim.visualModeKeyBindings": [
        {
            "before": [">"],
            "after": [">", "g", "v"]
        },
        {
            "before": ["<"],
            "after": ["<", "g", "v"]
        },
        {
            // Comment selected lines and exit visual mode with leader+c
            "before": ["<leader>", "c"],
            "commands": ["editor.action.commentLine", "extension.vim_escape"]
        },
        {
            // Select all occurrences of current selection with leader+a
            "before": ["<leader>", "a"],
            "commands": ["editor.action.selectHighlights"]
        },
        {
            // Sort selected lines
            "before": ["<leader>", "s", "s"],
            "commands": ["editor.action.sortLinesAscending"]
        },
        {
            // Transform to uppercase
            "before": ["<leader>", "u"],
            "commands": ["editor.action.transformToUppercase"]
        },
        {
            // Transform to lowercase
            "before": ["<leader>", "l"],
            "commands": ["editor.action.transformToLowercase"]
        }
    ],

    "vim.insertModeKeyBindings": [
        { "before": ["j", "j"], "after": ["<Esc>"] },
        {
            "before": ["<C-t>"],
            "commands": ["editor.action.indentLines"]
        },
        {
            "before": ["<C-d>"],
            "commands": ["editor.action.outdentLines"]
        }
    ],

    "vim.normalModeKeyBindingsNonRecursive": [
        // Buffers & Windows (L/H for quick switching)
        { "before": ["L"], "commands": ["workbench.action.nextEditor"] },
        { "before": ["H"], "commands": ["workbench.action.previousEditor"] },
        {
            "before": ["<leader>", "w"],
            "commands": ["workbench.action.splitEditor"],
        },
        {
            "before": ["<leader>", "z"],
            "commands": ["workbench.action.toggleZenMode"]
        }
        { "before": ["<leader>", "w", "w"], "commands": [":w"] },
        {
            "before": ["<leader>", "w", "c"],
            "commands": ["workbench.action.closeActiveEditor"],
        },

        // Navigation & Explorer
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.action.toggleSidebarVisibility"],
        },
        { "before": ["<leader>", "f"], "commands": ["revealInExplorer"] },
        { "before": ["<C-n>"], "commands": [":nohl"] },

        // LSP & Search
        { "before": ["K"], "commands": ["editor.action.showHover"] },
        {
            "before": ["g", "d"],
            "commands": ["editor.action.revealDefinition"],
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.referenceSearch.trigger"],
        },
        {
            "before": ["<leader>", "s", "f"],
            "commands": ["workbench.action.quickOpen"],
        },
        {
            "before": ["<leader>", "f", "f"],
            "commands": ["search.action.openNewEditor"]
        },
        {
            "before": ["<leader>", "f", "s"],
            "commands": ["workbench.action.findInFiles"],
        },

        // Debugging (Your original mappings)
        {
            "before": ["<leader>", "b"],
            "commands": ["editor.debug.action.toggleBreakpoint"],
        },
        {
            "before": ["<leader>", "d"],
            "commands": ["workbench.action.debug.start"],
        },
        {
            "before": ["<leader>", "s"],
            "commands": ["workbench.action.debug.stop"],
        },
        {
            "before": ["<leader>", "r"],
            "commands": ["workbench.action.debug.run"],
        },

        // Terminal
        {
            "before": ["<leader>", "t", "h"],
            "commands": ["workbench.action.terminal.new"],
        },
        {
            "before": ["<leader>", "t", "t"],
            "commands": ["workbench.action.createTerminalEditor"],
        },
    ],

    // --- JAVA & DEBUG SETTINGS ---
    "debug.autoExpandLazyVariables": "on",
    "java.debug.settings.showLogicalStructure": true,
    "java.debug.settings.showStaticVariables": true,

    // --- FORMATTERS ---
    "prettier.tabWidth": 4,
    "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

    // --- THEME & TOKEN CUSTOMIZATIONS (RESTORED) ---
    "workbench.colorTheme": "GitHub Dark Default",
    "workbench.colorCustomizations": {
        "[GitHub Dark Default]": {
            "sideBar.background": "#0d1116",
            "sideBarSectionHeader.background": "#0d1116",
            "terminal.background": "#0d1116",
            "terminal.border": "#0d1116",
            "panel.background": "#0d1116",
            "editorGroupHeader.tabsBackground": "#0d1116",
            "tab.inactiveBackground": "#0d1116",
        }
    },
    "workbench.iconTheme": "icons",
    "workbench.productIconTheme": "jetbrains-product-icons",
    "custom-ui-style.background.opacity": 1,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "constant",
                    "entity",
                    "keyword",
                    "storage",
                    "string",
                    "variable",
                ],
                "settings": { 
                    "fontStyle": "", 
                },
            },
        ],
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "*:java": { "fontStyle": "" },
        },
    },
    "nerdtree.hideSidebarWhenOpenFile": false,
    "nerdtree.alwaysShowSidebar": true,
    "extensions.ignoreRecommendations": true,
}
